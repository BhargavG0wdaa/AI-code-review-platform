# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets never get committed.

# Required. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Required for Phase 2 (the webhook bot) — it needs write access to POST a
# review comment on the PR. For the CLI alone, it's optional (read-only).
# Create one at https://github.com/settings/tokens
#   - Public repos: scope "public_repo"
#   - Private repos: scope "repo"
GITHUB_TOKEN=

# Phase 2 only. A random string YOU invent. You paste the same value into the
# GitHub webhook settings, and we use it to verify each webhook really came
# from GitHub (HMAC signature). Generate one with:  openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=
