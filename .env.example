# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets never get committed.

# Required. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Without it you can review PUBLIC PRs but you'll hit GitHub's
# low anonymous rate limit (60 req/hr). A token raises it to 5000/hr and
# is required for private repos.
# Create one at https://github.com/settings/tokens (scope: public_repo is enough)
GITHUB_TOKEN=
